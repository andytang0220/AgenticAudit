# API Configuration
API_TITLE=Compliance Monitoring Agent API
API_VERSION=0.1.0

# Server Configuration
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# CORS Configuration (comma-separated list of origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Database Configuration (when ready for database integration)
# DATABASE_URL=postgresql://user:password@localhost/compliance_db

# RAG/Agent Configuration (when ready for RAG integration)
# RAG_API_ENDPOINT=http://localhost:8001
# RAG_API_KEY=your-rag-api-key

# Bright Data Configuration (when ready for Bright Data integration)
# BRIGHT_DATA_API_KEY=your-bright-data-api-key
# BRIGHT_DATA_API_ENDPOINT=https://api.brightdata.com
